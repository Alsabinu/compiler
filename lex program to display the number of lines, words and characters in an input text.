%{
#include <stdio.h>
int lines = 0;
int words = 0;
int chars = 0;
%}

%%
\n      { lines++; chars++; }
[^\t\n ]+ { words++; chars += yyleng; }
.       { chars++; }
%%

int yywrap() { return 1; }

int main() {
    printf("Enter the text (Press Ctrl+D to end in Linux / Ctrl+Z then Enter in Windows):\n");
    yylex();

    printf("\nLines      : %d\n", lines);
    printf("Words      : %d\n", words);
    printf("Characters : %d\n", chars);

    return 0;
}


