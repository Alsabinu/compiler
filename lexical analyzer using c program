#include <stdio.h>
#include <ctype.h>
#include <string.h>
char keywords[][20] = {
    "int","float","char","double","if","else","while",
    "for","return","void","break","continue","switch",
    "case","default","do","long","short","unsigned",
    "signed","const","static","struct","union","enum"
};
int isKeyword(char str[])
{
    int n = sizeof(keywords)/sizeof(keywords[0]);
    for(int i=0;i<n;i++)
    {
        if(strcmp(str,keywords[i])==0)
            return 1;
    }
    return 0;
}
int main()
{
    FILE *fp;
    char ch;
    fp = fopen("input.txt","r");
    if(fp==NULL)
    {
        printf("Cannot open file.\n");
        return 0;
    }
    while((ch=fgetc(fp))!=EOF)
    {
        if(ch==' ' || ch=='\t' || ch=='\n')
            continue;
        if(ch=='/')
        {
            char next=fgetc(fp);
            if(next=='/')
            {
                while((ch=fgetc(fp))!='\n' && ch!=EOF);
                continue;
            }
            else if(next=='*')
            {
                char prev=' ';
                while((ch=fgetc(fp))!=EOF)
                {
                    if(prev=='*' && ch=='/')
                        break;
                    prev=ch;
                }
                continue;
            }
            else
            {
                printf("/\t\tOperator\n");
                ungetc(next,fp);
                continue;
            }
        }
        if(isalpha(ch) || ch=='_')
        {
            char word[100];
            int i=0;
            while(isalnum(ch) || ch=='_')
            {
                word[i++]=ch;
                ch=fgetc(fp);
            }
            word[i]='\0';
            ungetc(ch,fp);
            if(isKeyword(word))
                printf("%-15s Keyword\n",word);
            else
                printf("%-15s Identifier\n",word);
        }
        else if(isdigit(ch))
        {
            char num[100];
            int i=0;
            while(isdigit(ch) || ch=='.')
            {
                num[i++]=ch;
                ch=fgetc(fp);
            }
            num[i]='\0';
            ungetc(ch,fp);
            printf("%-15s Number\n",num);
        }
        else if(ch=='"')
        {
            char str[100];
            int i=0;
            while((ch=fgetc(fp))!='"' && ch!=EOF)
                str[i++]=ch;
            str[i]='\0';
            printf("\"%s\"\t\tString Literal\n",str);
        }
        else if(ch=='\'')
        {
            char c=fgetc(fp);
            fgetc(fp);
            printf("'%c'\t\tCharacter Literal\n",c);
        }
        else if(strchr("+-*=<>!%&|",ch))
        {
            printf("%c\t\tOperator\n",ch);
        }
        else if(strchr(";,(){}[]",ch))
        {
            printf("%c\t\tDelimiter\n",ch);
        }
    }
    fclose(fp);
    return 0;
}
