%{
#include <stdio.h>
int v = 0;
int c = 0;
%}

%%
[aeiouAEIOU]    { v++; }
[a-zA-Z]        { c++; }
\n              { return 0; }
.               { ; }
%%

int main() {
    printf("Enter a string:\n");
    yylex();

    printf("\nNumber of Vowels   : %d\n", v);
    printf("Number of Consonants : %d\n", c);

    return 0;
}

int yywrap() {
    return 1;
}
